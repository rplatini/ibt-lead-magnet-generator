{
	"name": "lead-magnet-generator",
	"version": "0.1.0",
	"private": true,
	"description": "Two-stage agent pipeline that turns brand guidelines into a custom lead-magnet template, then generates personalized PDFs from a target input.",
	"scripts": {
		"web": "tsx src/web/server/index.ts",
		"cli:build-template": "tsx src/cli/build-template.ts",
		"cli:generate-magnet": "tsx src/cli/generate-magnet.ts",
		"test": "NODE_ENV=test vitest run",
		"typecheck": "tsc --noEmit",
		"format": "biome check --write src/"
	},
	"dependencies": {
		"@anthropic-ai/claude-agent-sdk": "^0.2.136",
		"dotenv": "^16.4.5",
		"express": "^4.21.0",
		"handlebars": "^4.7.9",
		"multer": "^1.4.4",
		"pdf-parse": "1.1.4",
		"puppeteer": "^24.43.0",
		"zod": "^4.0.0"
	},
	"devDependencies": {
		"@biomejs/biome": "^1.9.4",
		"@types/express": "^4.17.21",
		"@types/multer": "^1.4.13",
		"@types/node": "^22.0.0",
		"@types/pdf-parse": "1.1.5",
		"tsx": "^4.19.0",
		"typescript": "^5.6.0",
		"vitest": "^2.1.0"
	},
	"engines": {
		"node": ">=20"
	}
}
